{
  "id": "tribal-touch",
  "name": "TribalTouch",
  "type": "Generative Groovebox",
  "author": "TribalTouch Developer",
  "binary_url": "",
  "source_url": "",
  "description": "A generative, 7-voice polyrhythmic drum machine and techno groovebox featuring deep Euclidean sequencing and live performance macros.",
  "features": {
    "usb_midi": false,
    "external_sync": ""
  },
  "mappings": [
    {
      "state_context": "Default State (Global Macros)",
      "primary_control": "S30",
      "modifiers": [],
      "parameter": "Density Bias",
      "description": "Left thins non-kick hits. Right adds soft ghost hits. (P03 Kick protected)",
      "type": "knob"
    },
    {
      "state_context": "Default State (Global Macros)",
      "primary_control": "S31",
      "modifiers": [],
      "parameter": "Decay Bias",
      "description": "Multiplier. Left shortens tails, right lengthens them within limits.",
      "type": "knob"
    },
    {
      "state_context": "Default State (Global Macros)",
      "primary_control": "S32",
      "modifiers": [],
      "parameter": "Velocity / Humanize",
